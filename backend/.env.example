# ─────────────────────────────────────────────────────────────────────────────
# AgroAI Backend — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=agroai-super-secret-key-change-in-production-please

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero config)
DATABASE_URL=sqlite+aiosqlite:///./agroai.db

# PostgreSQL (production — uncomment and fill):
# DATABASE_URL=postgresql+asyncpg://agroai:password@localhost:5432/agroai_db

# ── AI Chat (optional) ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── CORS (comma-separated origins) ───────────────────────────────────────────
# ALLOWED_ORIGINS=["http://localhost:5173","https://yourapp.vercel.app"]

# ── App Config ────────────────────────────────────────────────────────────────
DEBUG=true
