{
  "name": "agroai-root",
  "version": "1.0.0",
  "description": "Root forwarder for AgroAI Frontend and Backend",
  "scripts": {
    "postinstall": "npm install --prefix frontend",
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "backend-dev": "powershell -Command \"cd backend; .\\venv\\Scripts\\activate; uvicorn app.main:app --reload --port 8000\"",
    "backend-test": "powershell -Command \"cd backend; .\\venv\\Scripts\\activate; python -m pytest tests\""
  }
}
